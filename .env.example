# Backend (opcional)
# Se você estiver rodando com Docker Compose, estas variáveis já são definidas no docker-compose.yml.
# Para rodar localmente, copie este arquivo para `.env` e ajuste se necessário.

# Endpoint completo usado pelo backend/app/services/llm_service.py
OLLAMA_URL=http://localhost:11434/api/generate

# Base URL usada pelo LangChain Ollama (RAG e embeddings)
OLLAMA_BASE_URL=http://localhost:11434

# Modelos (Ollama)
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

